{
  "protocol": "P08",
  "name": "認知ワーク",
  "priority": 10,
  "rules": [
    {
      "id": "P08-INV-1",
      "type": "invariant",
      "description": "最重要タスクが午前帯（09-12）に設定",
      "metric": "morning_top_task_set",
      "operator": "bool_eq",
      "threshold": true,
      "window": "1d",
      "recovery_ref": "p08-deep-work.md#復旧手順"
    },
    {
      "id": "P08-INV-3",
      "type": "invariant",
      "description": "1セッション ≤ 90分",
      "metric": "max_session_min",
      "operator": "lte",
      "threshold": 90,
      "window": "1d",
      "recovery_ref": "p08-deep-work.md#復旧手順"
    },
    {
      "id": "P08-INV-4",
      "type": "invariant",
      "description": "セッション間休憩 ≥ 15分",
      "metric": "min_break_between_sessions",
      "operator": "gte",
      "threshold": 15,
      "window": "1d",
      "recovery_ref": "p08-deep-work.md#復旧手順"
    },
    {
      "id": "P08-VIO-1",
      "type": "violation",
      "description": "深い集中時間 < 3h が週3日以上",
      "metric": "low_focus_days_week",
      "operator": "weekly_count_gte",
      "threshold": 3,
      "window": "7d",
      "severity": "warn",
      "recovery_ref": "p08-deep-work.md#復旧手順"
    },
    {
      "id": "P08-VIO-2",
      "type": "violation",
      "description": "ディープワーク帯侵食日が週2日以上",
      "metric": "morning_block_invasion_days_week",
      "operator": "weekly_count_gte",
      "threshold": 2,
      "window": "7d",
      "severity": "warn",
      "recovery_ref": "p08-deep-work.md#復旧手順"
    },
    {
      "id": "P08-INV-5",
      "type": "invariant",
      "description": "深い集中時間 ≥ 3時間/日",
      "metric": "deep_work_min",
      "operator": "gte",
      "threshold": 180,
      "window": "1d",
      "recovery_ref": "p08-deep-work.md#復旧手順"
    }
  ]
}
